# Paths
GROUND_TARGET_PYTHON=.venv/bin/python
GROUND_TARGET_CONFIG=target_geolocation/config.json
GROUND_TARGET_MODEL=model/exp-3.engine
GROUND_TARGET_RUNS_DIR=runs
GROUND_TARGET_RUNTIME_DIR=/run/ground-target

# MAVLink and local bbox UDP
GROUND_TARGET_MAVLINK=udpin:0.0.0.0:14550
GROUND_TARGET_SOURCE_SYSTEM=245
GROUND_TARGET_BBOX_LISTEN=127.0.0.1:15100
GROUND_TARGET_BBOX_DESTINATION=127.0.0.1:15100

# IMX219 capture; calibration resolution must match output resolution
GROUND_TARGET_SENSOR_ID=0
GROUND_TARGET_CAPTURE_WIDTH=1280
GROUND_TARGET_CAPTURE_HEIGHT=720
GROUND_TARGET_OUTPUT_WIDTH=1280
GROUND_TARGET_OUTPUT_HEIGHT=720
GROUND_TARGET_FRAMERATE=30
GROUND_TARGET_FLIP_METHOD=0
GROUND_TARGET_CAMERA_ID=down_cam

# YOLO
GROUND_TARGET_TRACKER=bytetrack.yaml
GROUND_TARGET_IMG_SIZE=640
GROUND_TARGET_CONFIDENCE=0.60

# Flight recorder. Images are rate-limited; bbox and telemetry remain full-rate.
GROUND_TARGET_RECORD_IMAGES=detections
GROUND_TARGET_RECORD_IMAGE_FPS=2
GROUND_TARGET_RECORD_ANNOTATED=0
GROUND_TARGET_JPEG_QUALITY=90
GROUND_TARGET_MIN_FREE_DISK_GB=5
GROUND_TARGET_PRINT_JSON=0

# Raw training video. MJPEG AVI segments keep previous files usable after a crash.
GROUND_TARGET_RECORD_VIDEO=1
GROUND_TARGET_VIDEO_FPS=10
GROUND_TARGET_VIDEO_SEGMENT_SECONDS=60
GROUND_TARGET_VIDEO_QUALITY=85
GROUND_TARGET_VIDEO_MAX_TOTAL_GB=20
